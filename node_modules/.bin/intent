#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/home/runner/work/wrapped/wrapped/node_modules/.pnpm/@tanstack+intent@0.0.44/node_modules/@tanstack/intent/dist/node_modules:/home/runner/work/wrapped/wrapped/node_modules/.pnpm/@tanstack+intent@0.0.44/node_modules/@tanstack/intent/node_modules:/home/runner/work/wrapped/wrapped/node_modules/.pnpm/@tanstack+intent@0.0.44/node_modules/@tanstack/node_modules:/home/runner/work/wrapped/wrapped/node_modules/.pnpm/@tanstack+intent@0.0.44/node_modules:/home/runner/work/wrapped/wrapped/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/home/runner/work/wrapped/wrapped/node_modules/.pnpm/@tanstack+intent@0.0.44/node_modules/@tanstack/intent/dist/node_modules:/home/runner/work/wrapped/wrapped/node_modules/.pnpm/@tanstack+intent@0.0.44/node_modules/@tanstack/intent/node_modules:/home/runner/work/wrapped/wrapped/node_modules/.pnpm/@tanstack+intent@0.0.44/node_modules/@tanstack/node_modules:/home/runner/work/wrapped/wrapped/node_modules/.pnpm/@tanstack+intent@0.0.44/node_modules:/home/runner/work/wrapped/wrapped/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../@tanstack/intent/dist/cli.mjs" "$@"
else
  exec node  "$basedir/../@tanstack/intent/dist/cli.mjs" "$@"
fi
